# Electro — local environment variables.
# Copy this file to .env.local and fill in the values. .env.local is gitignored,
# so your secrets stay on your machine.

# ── Spotify (OAuth + playlist read) ──────────────────────────────────────────
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Copy its Client ID and Client Secret into the two lines below.
# 3. In the app's settings, add this EXACT Redirect URI:
#       http://localhost:3000/api/auth/spotify/callback
#    (If Spotify rejects "localhost", use http://127.0.0.1:3000/api/auth/spotify/callback
#     in BOTH the dashboard and SPOTIFY_REDIRECT_URI below — the two must match.)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the Redirect URI registered in the Spotify dashboard exactly.
# Leave as-is for local dev; change to your production URL when you deploy.
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback

# ── Waitlist (landing page) ──────────────────────────────────────────────────
# Formspree form endpoint — see https://formspree.io/
WAITLIST_FORMSPREE_ENDPOINT=
